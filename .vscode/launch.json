{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask: Run App (uv)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload"
            ],
            "jinja": true,
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: run.py (uv run)",
            "type": "python",
            "request": "launch",
            "program": "run.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python"
        }
    ]
}
